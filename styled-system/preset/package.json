{
  "name": "@likec4/style-preset",
  "description": "Shared PandaCSS preset used in LikeC4",
  "license": "MIT",
  "version": "1.58.0",
  "bugs": "https://github.com/likec4/likec4/issues",
  "homepage": "https://likec4.dev",
  "author": "Denis Davydkov <denis@davydkov.com>",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "generate": "tsdown",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "pack": "pnpm pack",
    "postpack": "likec4ops postpack",
    "lint:package": "pnpx publint ./package.tgz",
    "clean": "likec4ops clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/likec4/likec4.git",
    "directory": "styled-system/preset"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "types": "dist/index.d.mts",
    "module": "dist/index.mjs",
    "exports": {
      ".": {
        "sources": "./src/index.ts",
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./defaults": {
        "sources": "./src/defaults/index.ts",
        "types": "./dist/defaults/index.d.mts",
        "import": "./dist/defaults/index.mjs",
        "default": "./dist/defaults/index.mjs"
      },
      "./dev": "./dev.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "sources": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./defaults": {
      "sources": "./src/defaults/index.ts",
      "types": "./dist/defaults/index.d.mts",
      "import": "./dist/defaults/index.mjs",
      "default": "./dist/defaults/index.mjs"
    },
    "./src": "./src/index.ts",
    "./dev": "./dev.mjs"
  },
  "dependencies": {
    "remeda": "catalog:utils",
    "@pandacss/dev": "catalog:css",
    "@pandacss/types": "catalog:css",
    "@radix-ui/colors": "catalog:css"
  },
  "devDependencies": {
    "@types/react": "catalog:react",
    "@types/node": "catalog:",
    "@types/react-dom": "catalog:react",
    "@likec4/devops": "workspace:*",
    "@likec4/tsconfig": "workspace:*",
    "@mantine/core": "catalog:mantine",
    "@mantine/vanilla-extract": "catalog:mantine",
    "json5": "catalog:utils",
    "nano-spawn": "catalog:externals",
    "typescript": "catalog:",
    "tsdown": "catalog:tsdown"
  }
}
