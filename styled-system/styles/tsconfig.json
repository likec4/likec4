{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@likec4/tsconfig/base.json",
  "compilerOptions": {
    "target": "es2024",
    "allowImportingTsExtensions": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "types": [
      "react",
      "node"
    ],
    "skipLibCheck": true
  },
  "include": [
    "*.ts",
    "*.mts"
  ]
}
