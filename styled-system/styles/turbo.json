{
  "$schema": "https://turbo.build/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "sources": {
      "dependsOn": [
        "^sources"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "generate": {
      "dependsOn": ["sources"],
      "cache": false
    },
    "build": {
      "dependsOn": ["sources"],
      "cache": false
    }
  }
}
