---
import LikeC4View from './LikeC4View.astro'
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden px-6 pt-28 pb-20">
  <!-- Dot grid background -->
  <div class="hero-dots absolute inset-0 pointer-events-none opacity-[0.12] dark:opacity-[0.06]"></div>

  <!-- Radial glow positioned toward the diagram -->
  <div class="absolute top-1/4 right-1/4 w-[600px] h-[400px] rounded-full pointer-events-none bg-cyan-400/[0.04] dark:bg-cyan-400/[0.06] blur-3xl">
  </div>

  <div class="relative z-10 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-16 items-center">
    <!-- Left column: text content, LEFT-ALIGNED -->
    <div class="lp-anim-left max-w-xl">
      <!-- Badge -->
      <div class="lp-anim lp-d1">
        <span
          class="inline-flex items-center gap-2 px-3.5 py-1.5 text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-cyan-700 dark:text-cyan-400 border border-cyan-600/25 dark:border-cyan-400/20 rounded-full"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 dark:bg-cyan-400 animate-pulse"></span>
          Open Source
        </span>
      </div>

      <!-- Headline -->
      <h1 class="lp-display mt-8 text-[2.75rem] sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-[-0.035em] leading-[1.05] text-stone-900 dark:text-white">
        Architecture <br />as Code
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-base sm:text-lg leading-relaxed text-stone-500 dark:text-zinc-400 max-w-md">
        Describe your software architecture in a simple DSL. Get instant diagrams, version everything with Git, and let
        your IDE validate it as you type.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-3">
        <a
          href="/tutorial"
          class="group inline-flex items-center gap-2 px-6 py-3 bg-cyan-500 dark:bg-cyan-500 text-cyan-950 dark:text-cyan-950 font-semibold text-sm rounded-lg transition-all duration-200 shadow-lg shadow-cyan-600/20 dark:shadow-cyan-500/15 hover:shadow-xl hover:shadow-cyan-600/25 dark:hover:shadow-cyan-500/25 hover:-translate-y-px no-underline"
        >
          Get Started
          <svg
            class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="https://github.com/likec4/likec4"
          target="_blank"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-stone-500 dark:text-zinc-400 border border-stone-300/80 dark:border-zinc-700 rounded-lg hover:text-stone-700 dark:hover:text-zinc-200 hover:border-stone-400 dark:hover:border-zinc-600 transition-all duration-200 no-underline"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z">
            </path>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>

    <!-- Right column: LIVE DIAGRAM in terminal chrome -->
    <div class="lp-anim-right relative">
      <div class="rounded-xl border border-stone-300/60 dark:border-zinc-700/60 bg-white/80 dark:bg-zinc-900/50 backdrop-blur-sm shadow-xl shadow-stone-300/30 dark:shadow-cyan-500/5 overflow-hidden">
        <!-- Terminal chrome bar -->
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-stone-200 dark:border-zinc-800">
          <span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span>
          <span class="ml-3 text-xs text-stone-400 dark:text-zinc-600 font-mono">landscape-view.c4</span>
        </div>
        <!-- Diagram -->
        <div class="p-4 min-h-[320px] flex items-center justify-center">
          <LikeC4View viewId="index" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-dots {
  background-image: radial-gradient(circle, #06b6d4 0.6px, transparent 0.6px);
  background-size: 28px 28px;
  mask-image: radial-gradient(ellipse 75% 55% at 50% 40%, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 75% 55% at 50% 40%, black 20%, transparent 70%);
}
</style>
