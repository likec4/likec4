---
interface Contributor {
  login: string
  avatar_url: string
  html_url: string
  contributions: number
  type: string
}

let contributors: Contributor[] = []

try {
  const res = await fetch('https://api.github.com/repos/likec4/likec4/contributors?per_page=100')
  if (res.ok) {
    const data: Contributor[] = await res.json()
    contributors = data.filter((c) => c.type === 'User')
  }
} catch {
  // Silently fail — section will be hidden if no contributors loaded
}
---

<section class="py-20 md:py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center lp-reveal">
      <span
        class="lp-display text-[0.6875rem] font-semibold tracking-[0.2em] uppercase text-cyan-600 dark:text-cyan-400"
      >
        Community
      </span>
      <h2 class="lp-display text-2xl sm:text-3xl font-bold tracking-tight text-stone-900 dark:text-white mt-4">
        Built by the community
      </h2>
      <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400 max-w-md mx-auto mt-3">
        Thanks to everyone who has contributed to LikeC4.
      </p>
    </div>

    {contributors.length > 0 && (
      <div class="mt-12 flex flex-wrap justify-center gap-3 lp-reveal">
        {contributors.map((contributor) => (
          <a
            href={contributor.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative no-underline"
            title={`@${contributor.login} — ${contributor.contributions} contributions`}
          >
            <img
              src={`${contributor.avatar_url}&s=80`}
              alt={contributor.login}
              width="40"
              height="40"
              loading="lazy"
              class="w-10 h-10 rounded-full border-2 border-stone-200 dark:border-zinc-800 grayscale opacity-80 transition-all duration-200 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110 group-hover:border-cyan-500/50 group-hover:shadow-lg group-hover:shadow-cyan-500/10"
            />
          </a>
        ))}
      </div>
    )}

    <div class="mt-8 text-center lp-reveal">
      <a
        href="https://github.com/likec4/likec4"
        target="_blank"
        class="inline-flex items-center gap-2 text-sm font-medium text-stone-500 dark:text-zinc-500 hover:text-cyan-600 dark:hover:text-cyan-400 no-underline transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        Become a contributor
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M7 17l9.2-9.2M17 17V7H7" />
        </svg>
      </a>
    </div>
  </div>
</section>
