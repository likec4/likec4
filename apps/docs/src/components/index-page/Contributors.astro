---
interface Contributor {
  login: string
  avatar_url: string
  html_url: string
  contributions: number
  type: string
}

let contributors: Contributor[] = []

try {
  const res = await fetch('https://api.github.com/repos/likec4/likec4/contributors?per_page=100')
  if (res.ok) {
    const data: Contributor[] = await res.json()
    contributors = data.filter((c) => c.type === 'User')
  }
} catch {
  // Silently fail — section will be hidden if no contributors loaded
}
---

<section class="relative py-24 md:py-32 lg:py-40 px-6 overflow-hidden">
  <!-- Radial glow background -->
  <div class="absolute top-[30%] left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full pointer-events-none bg-cyan-400/[0.04] dark:bg-cyan-400/[0.08] blur-3xl">
  </div>

  <div class="relative z-10 max-w-4xl mx-auto">
    <div class="text-center lp-reveal">
      <span
        class="lp-display text-[0.6875rem] font-semibold tracking-[0.2em] uppercase text-cyan-600 dark:text-cyan-400"
      >
        Community
      </span>
      <h2 class="lp-display text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-stone-900 dark:text-white mt-4">
        Built by the community
      </h2>
      <p class="text-base sm:text-lg leading-relaxed text-stone-500 dark:text-zinc-300 max-w-[600px] mx-auto mt-4 lg:mt-8 font-medium">
        Thanks to everyone who has contributed to LikeC4.
      </p>
    </div>

    {contributors.length > 0 && (
      <div class="mt-12 flex flex-wrap justify-center gap-3 lp-reveal">
        {contributors.map((contributor) => (
          <a
            href={contributor.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative no-underline"
            title={`@${contributor.login} — ${contributor.contributions} contributions`}
          >
            <img
              src={`${contributor.avatar_url}&s=80`}
              alt={contributor.login}
              width="40"
              height="40"
              loading="lazy"
              class="w-10 h-10 rounded-full border-2 border-stone-200 dark:border-zinc-800 grayscale opacity-80 transition-all duration-200 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110 group-hover:border-cyan-500/50 group-hover:shadow-lg group-hover:shadow-cyan-500/10"
            />
          </a>
        ))}
      </div>
    )}

    <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center lp-reveal">
      <a
        href="https://github.com/likec4/likec4"
        target="_blank"
        class="inline-flex items-center gap-2.5 px-7 py-3.5 bg-cyan-500 text-cyan-950 font-semibold text-base rounded-lg transition-all duration-200 shadow-lg shadow-cyan-600/20 dark:shadow-cyan-500/15 hover:shadow-xl hover:shadow-cyan-600/25 dark:hover:shadow-cyan-500/25 hover:-translate-y-px no-underline"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        Star on GitHub
      </a>
      <a
        href="https://discord.gg/86ZSpjKAdA"
        target="_blank"
        class="inline-flex items-center gap-2.5 px-7 py-3.5 text-base font-medium text-stone-700 dark:text-white border border-stone-200/60 dark:border-zinc-600 rounded-lg hover:text-stone-900 dark:hover:text-white hover:border-stone-300 dark:hover:border-zinc-500 transition-all duration-200 no-underline"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z" />
        </svg>
        Join Discord
      </a>
    </div>
  </div>
</section>
