---
import { Code } from '@astrojs/starlight/components'

const dslSnippet = `specification {
  element actor {
    style {
      shape person
    }
  }
  element system
  element component
  relationship async
}
`
---

<section id="features" class="py-24 md:py-32 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Left-aligned header -->
    <div class="mb-16 lp-reveal">
      <span
        class="lp-display text-[0.6875rem] font-semibold tracking-[0.2em] uppercase text-cyan-600 dark:text-cyan-400"
      >
        Capabilities
      </span>
      <h2 class="lp-display text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-stone-900 dark:text-white mt-4">
        Everything you need
      </h2>
      <p class="text-base md:text-lg leading-relaxed text-stone-500 dark:text-zinc-400 max-w-xl mt-4">
        Built for modern development teams who value clarity, collaboration, and code-first workflows.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-auto">
      <!-- Large tile: Your Language (spans 2 cols, 2 rows on desktop) -->
      <div class="lp-reveal lp-stagger-1 md:col-span-2 lg:col-span-2 lg:row-span-2 group">
        <div class="h-full p-6 lg:p-8 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <span class="lp-display text-xs font-bold tracking-[0.15em] text-cyan-600 dark:text-cyan-400/50">DSL</span>
          <h3 class="lp-display text-xl font-bold text-stone-800 dark:text-zinc-100 mt-2 mb-2">Your Language</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400 mb-6 max-w-lg">
            Define your system using a clean, readable DSL designed for clarity and control. LLM-friendly syntax that AI
            agents understand natively.
          </p>
          <!-- Syntax-highlighted code inside the tile -->
          <div class="rounded-lg overflow-hidden border border-stone-200 dark:border-zinc-800/40 text-sm">
            <Code code={dslSnippet} lang="likec4" />
          </div>
        </div>
      </div>

      <!-- Small tile: Versioned -->
      <div class="lp-reveal lp-stagger-2 group">
        <div class="h-full p-6 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <div class="w-10 h-10 rounded-lg bg-stone-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M6 3v12M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 9a9 9 0 0 1-9 9">
              </path>
            </svg>
          </div>
          <h3 class="lp-display text-lg font-bold text-stone-800 dark:text-zinc-100 mb-2">Versioned</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400">
            Store diagrams in Git, track diffs, and collaborate with familiar developer workflows.
          </p>
        </div>
      </div>

      <!-- Small tile: AI-Friendly -->
      <div class="lp-reveal lp-stagger-3 group">
        <div class="h-full p-6 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <div class="w-10 h-10 rounded-lg bg-stone-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456z">
              </path>
            </svg>
          </div>
          <h3 class="lp-display text-lg font-bold text-stone-800 dark:text-zinc-100 mb-2">AI-Friendly</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400">
            Expose your architecture to AI agents via MCP server or API — no extra effort.
          </p>
        </div>
      </div>

      <!-- Medium tile: Instant Visual Feedback -->
      <div class="lp-reveal lp-stagger-4 group">
        <div class="h-full p-6 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <div class="w-10 h-10 rounded-lg bg-stone-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z">
              </path>
              <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"></path>
            </svg>
          </div>
          <h3 class="lp-display text-lg font-bold text-stone-800 dark:text-zinc-100 mb-2">Instant Visual Feedback</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400">
            See diagrams update as you type — real-time visualization in your VSCode editor, no manual sync.
          </p>
        </div>
      </div>

      <!-- Medium tile: Integrate Anywhere -->
      <div class="lp-reveal lp-stagger-5 group">
        <div class="h-full p-6 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <div class="w-10 h-10 rounded-lg bg-stone-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25z">
              </path>
            </svg>
          </div>
          <h3 class="lp-display text-lg font-bold text-stone-800 dark:text-zinc-100 mb-2">Integrate Anywhere</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400">
            Embed interactive diagrams into docs, websites or apps — React components or Web Components.
          </p>
        </div>
      </div>

      <!-- Small tile: C4 — Evolved -->
      <div class="lp-reveal lp-stagger-6 group">
        <div class="h-full p-6 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <div class="w-10 h-10 rounded-lg bg-stone-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25zM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25z">
              </path>
            </svg>
          </div>
          <h3 class="lp-display text-lg font-bold text-stone-800 dark:text-zinc-100 mb-2">C4 — Evolved</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400">
            Built on the proven C4 model, extended with flexibility and modern customization options.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
