---
import { Code } from '@astrojs/starlight/components'

const dslSnippet = `specification {
  element actor {
    style {
      shape person
    }
  }
  element system
  element component
  relationship async
}
`
---

<section id="features" class="py-24 md:py-32 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Left-aligned header -->
    <div class="mb-16 lp-reveal">
      <span
        class="lp-display text-[0.6875rem] font-semibold tracking-[0.2em] uppercase text-cyan-600 dark:text-cyan-400"
      >
        Capabilities
      </span>
      <h2 class="lp-display text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-stone-900 dark:text-white mt-4">
        Everything you need
      </h2>
      <p class="text-base md:text-lg font-medium leading-relaxed text-stone-500 dark:text-zinc-400 max-w-2xl mt-4">
        A complete toolkit for modeling, visualizing, and validating your software architecture — all from code.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-auto">
      <!-- Large tile: Your Language (spans 2 cols, 2 rows on desktop) -->
      <div class="lp-reveal lp-stagger-1 md:col-span-2 lg:col-span-2 lg:row-span-2 group">
        <div class="h-full p-7 lg:p-8 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <svg
            class="w-6 h-6 text-cyan-500 mb-3"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
          </svg>
          <h3 class="lp-display text-xl font-bold text-stone-800 dark:text-zinc-100 mt-2 mb-2">Your Language</h3>
          <p class="text-base leading-relaxed text-stone-500 dark:text-zinc-400 mb-6 max-w-lg font-medium">
            Define your system with a clean DSL, designed for clarity and control. LLM-friendly syntax that AI agents
            understand natively.
          </p>
          <!-- Syntax-highlighted code inside the tile -->
          <div class="rounded-lg overflow-hidden border border-stone-200 dark:border-zinc-800/40 text-sm">
            <Code code={dslSnippet} lang="likec4" />
          </div>
        </div>
      </div>

      <!-- Small tile: Versioned -->
      <div class="lp-reveal lp-stagger-2 group">
        <div class="h-full p-7 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <svg
            class="w-6 h-6 text-cyan-500 mb-3"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M6 3v12M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 9a9 9 0 0 1-9 9" />
          </svg>
          <h3 class="lp-display text-lg font-semibold text-stone-800 dark:text-zinc-100 mb-2">Versioned</h3>
          <p class="text-base leading-snug text-stone-500 dark:text-zinc-400">
            Store diagrams in Git, track changes, and collaborate using familiar workflows.
          </p>
        </div>
      </div>

      <!-- Small tile: AI-Friendly -->
      <div class="lp-reveal lp-stagger-3 group">
        <div class="h-full p-7 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <svg
            class="w-6 h-6 text-cyan-500 mb-3"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456z" />
          </svg>
          <h3 class="lp-display text-lg font-semibold text-stone-800 dark:text-zinc-100 mb-2">AI-Friendly</h3>
          <p class="text-base leading-snug text-stone-500 dark:text-zinc-400">
            Expose your architecture context to AI agents via MCP server or API — no extra effort.
          </p>
        </div>
      </div>

      <!-- Medium tile: Interactive Views -->
      <div class="lp-reveal lp-stagger-4 group">
        <div class="h-full p-7 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <svg
            class="w-6 h-6 text-cyan-500 mb-3"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" />
          </svg>
          <h3 class="lp-display text-lg font-semibold text-stone-800 dark:text-zinc-100 mb-2">Interactive Views</h3>
          <p class="text-base leading-snug text-stone-500 dark:text-zinc-400">
            Navigate and explore your architecture diagrams interactively. Drill down into components and relationships.
          </p>
        </div>
      </div>

      <!-- Medium tile: Integrate Anywhere -->
      <div class="lp-reveal lp-stagger-5 group">
        <div class="h-full p-7 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <svg
            class="w-6 h-6 text-cyan-500 mb-3"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25z" />
          </svg>
          <h3 class="lp-display text-lg font-semibold text-stone-800 dark:text-zinc-100 mb-2">Integrate Anywhere</h3>
          <p class="text-base leading-snug text-stone-500 dark:text-zinc-400">
            Embed interactive diagrams into docs, websites or apps — via Vite Plugin, React or Web Components.
          </p>
        </div>
      </div>

      <!-- Small tile: Diff & Validation -->
      <div class="lp-reveal lp-stagger-6 group">
        <div class="h-full p-7 bg-white dark:bg-zinc-900/40 border border-stone-200 dark:border-zinc-800/70 shadow-sm dark:shadow-none rounded-xl transition-all duration-300 hover:border-cyan-500/30 dark:hover:border-cyan-400/20 hover:shadow-lg hover:shadow-cyan-500/5">
          <svg
            class="w-6 h-6 text-cyan-500 mb-3"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <h3 class="lp-display text-lg font-semibold text-stone-800 dark:text-zinc-100 mb-2">Diff & Validation</h3>
          <p class="text-base leading-snug text-stone-500 dark:text-zinc-400">
            Validate changes automatically. Catch architectural drift and breaking changes before they ship.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
