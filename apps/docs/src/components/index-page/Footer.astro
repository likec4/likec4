---
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro'
import Logo from '../Logo.astro'
const currentYear = new Date().getFullYear()

const footerLinks = [
  { label: 'Docs', href: '/tutorial/' },
  { label: 'Playground', href: 'https://playground.likec4.dev/w/tutorial/' },
  { label: 'Language Reference', href: '/dsl/intro/' },
  { label: 'GitHub', href: 'https://github.com/likec4/likec4' },
  { label: 'Discord', href: 'https://discord.gg/86ZSpjKAdA' },
]
---

<footer class="border-t border-stone-200 dark:border-zinc-800/80 px-6 py-8">
  <div class="max-w-7xl mx-auto">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <Logo loading="lazy" />
        <span class="text-sm text-stone-500 dark:text-zinc-600">Architecture as code.</span>
      </div>
      <nav class="flex flex-wrap items-center gap-5">
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-stone-500 dark:text-zinc-600 hover:text-stone-700 dark:hover:text-zinc-300 no-underline transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Bottom row -->
    <div class="mt-6 pt-4 border-t border-stone-200/40 dark:border-zinc-800/40 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-stone-400 dark:text-zinc-700">
        &copy; 2023-{currentYear} LikeC4. Released under the MIT License.
      </p>
      <div class="flex items-center gap-3">
        <SocialIcons />
      </div>
    </div>
  </div>
</footer>
