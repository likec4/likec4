{
  "extends": "@likec4/tsconfig/base.json",
  "compilerOptions": {
    "noUnusedParameters": false,
    "composite": true,
    "incremental": true,
    "lib": [
      "ES2024",
      "WebWorker"
    ],
    "rootDirs": [
      "src",
      "."
    ]
  },
  "include": [
    "src",
    "*.ts"
  ],
  "references": [
    {
      "path": "../core/"
    },
    {
      "path": "../log/"
    },
    {
      "path": "../config/"
    },
    {
      "path": "../layouts/"
    },
    {
      "path": "../vscode-preview/tsconfig.protocol.json"
    },
    {
      "path": "../language-server/"
    },
    {
      "path": "../language-services/"
    }
  ]
}
