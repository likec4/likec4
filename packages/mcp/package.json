{
  "name": "@likec4/mcp",
  "description": "Model Context Protocol server for LikeC4",
  "license": "MIT",
  "version": "1.56.0",
  "bugs": "https://github.com/likec4/likec4/issues",
  "homepage": "https://likec4.dev",
  "author": "Denis Davydkov <denis@davydkov.com>",
  "type": "module",
  "bin": {
    "likec4-mcp": "bin/likec4-mcp.mjs"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "**/package.json",
    "!**/__*/**",
    "!**/*.spec.*",
    "!**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/likec4/likec4.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "keywords": [
    "likec4",
    "mcp",
    "model context protocol",
    "server"
  ],
  "scripts": {
    "typecheck": "tsc -b --verbose",
    "build": "tsdown",
    "preinspector": "tsdown",
    "inspector": "DANGEROUSLY_OMIT_AUTH=1 LIKEC4_WORKSPACE=../../examples pnpx @modelcontextprotocol/inspector node bin/likec4-mcp.mjs",
    "pack": "pnpm pack",
    "postpack": "likec4ops postpack",
    "clean": "likec4ops clean",
    "test": "vitest run --no-isolate",
    "vitest:ui": "vitest --no-isolate --ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "catalog:externals",
    "bundle-require": "catalog:externals",
    "esbuild": "catalog:esbuild",
    "std-env": "catalog:externals"
  },
  "devDependencies": {
    "@hono/mcp": "catalog:hono",
    "@hono/node-server": "catalog:hono",
    "@likec4/config": "workspace:*",
    "@likec4/core": "workspace:*",
    "@likec4/devops": "workspace:*",
    "@likec4/language-server": "workspace:*",
    "@likec4/language-services": "workspace:*",
    "@likec4/layouts": "workspace:*",
    "@likec4/log": "workspace:*",
    "@likec4/tsconfig": "workspace:*",
    "@vitest/ui": "catalog:vitest",
    "hono": "catalog:hono",
    "langium": "catalog:langium",
    "@modelcontextprotocol/sdk": "catalog:mcp",
    "@types/node": "catalog:",
    "tinyrainbow": "catalog:utils",
    "defu": "catalog:utils",
    "citty": "catalog:utils",
    "tsdown": "catalog:",
    "remeda": "catalog:utils",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest",
    "vscode-uri": "catalog:vscode",
    "zod": "catalog:externals"
  }
}
