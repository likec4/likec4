exports[`mermaid validity > create degrades to a header participant when the actor is used before its create 1`] = `
"sequenceDiagram
  participant A as Alice
  participant B as Bob
  participant C as Carol
  A->>C: use carol early
  A->>B: something
"
`;

exports[`mermaid validity > outer-scope marker after a frame is emitted AFTER end, not inside the frame 1`] = `
"sequenceDiagram
  participant A as Alice
  participant B as Bob
  rect rgb(220, 220, 250)
    A->>B: inside frame
  end
  Note over A,B: done
  A->>B: after frame
"
`;

exports[`participant declarations in node order 1`] = `
"sequenceDiagram
  participant A as Alice
  participant B as Bob
  participant C as Carol
  A->>B: x
"
`;

exports[`showcase — all constructs end-to-end (paste into mermaid.live to verify) 1`] = `
"sequenceDiagram
autonumber 1 1
  participant User as User
  participant Web as Web
  participant Api as API
  participant Auth as Auth
  participant Payment as Payment
  participant Notifier as Notifier
  participant Db as Database
  activate User
  User->>Web: browse
  Note over User,Web: Shopping phase
  alt items in cart
    User->>Web: click checkout
    Web->>Api: initiate checkout
  else abandoned cart
    Web->>User: reminder
    break empty cart
      User-->>Web: abort
    end
  else 
    Web->Api: fallback
  end
  opt address valid
    User->>Web: address
  end
  Note left of Web: Address validation
  loop retry 3 times
    rect rgb(220, 220, 250)
      Api->>Payment: charge
    end
    critical payment success
      Payment->>Api: confirmed
    option insufficient funds
      Payment->>Api: declined
    end
  end
  par sync record
    Api->>Db: insert
  and async notify
    Api->>Notifier: notify
  end
  Note right of Api: Payment confirmed
  User->>Web: order confirmation
  deactivate User
"
`;
