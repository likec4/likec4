{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@likec4/tsconfig/base.json",
  "compilerOptions": {
    "customConditions": [
      "sources"
    ],
    "composite": true,
    "incremental": true,
    "lib": [
      "ES2024"
    ],
    "target": "ES2024",
    "rootDirs": [
      "src",
      "."
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "build.config.ts",
    "package.json"
  ],
  "references": [
    {
      "path": "../config/"
    },
    {
      "path": "../core/"
    },
    {
      "path": "../generators/"
    },
    {
      "path": "../language-server/"
    },
    {
      "path": "../layouts/"
    },
    {
      "path": "../log/"
    }
  ]
}
