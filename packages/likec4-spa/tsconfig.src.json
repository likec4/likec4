{
  "extends": "@likec4/tsconfig/react-lib.json",
  "compilerOptions": {
    "customConditions": [
      "sources"
    ],
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "noPropertyAccessFromIndexSignature": false,
    "module": "Preserve",
    "tsBuildInfoFile": "lib/src/.tsbuildinfo",
    "outDir": "lib/src",
    "rootDirs": [
      "src",
      "codegen"
    ],
    "types": [
      "vite/client",
      "@likec4/vite-plugin/modules"
    ]
  },
  "include": [
    "src/",
    "codegen/"
  ],
  "references": [
    {
      "path": "../core/"
    },
    {
      "path": "../vite-plugin/"
    },
    {
      "path": "../diagram/tsconfig.src.json"
    },
    {
      "path": "../../styled-system/styles/"
    },
    {
      "path": "../../styled-system/preset/"
    }
  ]
}
