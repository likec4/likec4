{
  "name": "@likec4/spa",
  "private": true,
  "description": "Single-page application for rendering architecture diagrams",
  "version": "1.59.2",
  "license": "MIT",
  "homepage": "https://likec4.dev",
  "author": "Denis Davydkov <denis@davydkov.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/likec4/likec4.git",
    "directory": "packages/likec4-spa"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --build --verbose",
    "clean": "likec4ops clean",
    "predev": "pandacss codegen",
    "dev": "tsx watch --conditions=sources --exclude=\"./../../{examples,e2e,styled-system}/**/*.{js,ts,mjs,mts}\" --exclude=\"./../core/src/styles/**/*.ts\" ./start-dev.ts",
    "dev:debug": "tsx --inspect-brk --conditions=sources ./start-dev.ts",
    "dev:single-project": "pnpm dev ../../examples/cloud-system",
    "dev:docs": "pnpm dev ../../apps/docs/src",
    "dev:playground:deployment": "pnpm dev ../../apps/playground/src/examples/deployment",
    "dev:playground:dynamic": "pnpm dev ../../apps/playground/src/examples/dynamic",
    "dev:template": "pnpm dev ../create-likec4/template",
    "dev:e2e": "pnpm dev ../../e2e/src",
    "test": "vitest run --no-isolate",
    "vitest:ui": "vitest --no-isolate --ui"
  },
  "dependencies": {
    "@likec4/core": "workspace:*",
    "immer": "catalog:utils",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "use-sync-external-store": "catalog:react"
  },
  "devDependencies": {
    "@dagrejs/dagre": "catalog:",
    "@fontsource-variable/ibm-plex-sans": "catalog:",
    "@likec4/config": "workspace:*",
    "@likec4/devops": "workspace:*",
    "@likec4/diagram": "workspace:*",
    "@likec4/icons": "workspace:*",
    "@likec4/layouts": "workspace:*",
    "@likec4/log": "workspace:*",
    "@likec4/styles": "workspace:*",
    "@likec4/tsconfig": "workspace:*",
    "@likec4/vite-plugin": "workspace:*",
    "@mantine/core": "catalog:mantine",
    "@mantine/hooks": "catalog:mantine",
    "@nanostores/react": "catalog:react",
    "@pandacss/dev": "catalog:css",
    "@react-hookz/web": "catalog:react",
    "@rolldown/plugin-babel": "catalog:vite",
    "@tabler/icons-react": "catalog:react",
    "@tanstack/ai": "catalog:ai",
    "@tanstack/ai-client": "catalog:ai",
    "@tanstack/ai-react": "catalog:ai",
    "@tanstack/ai-react-ui": "catalog:ai",
    "@tanstack/react-router": "catalog:tanstack",
    "@tanstack/router-cli": "catalog:tanstack",
    "@tanstack/router-vite-plugin": "catalog:tanstack",
    "@tsdown/css": "catalog:tsdown",
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:externals",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:vite",
    "@xstate/react": "catalog:xstate",
    "@xstate/store": "catalog:xstate",
    "@xyflow/react": "catalog:xyflow",
    "@xyflow/system": "catalog:xyflow",
    "autoprefixer": "^10.5.4",
    "babel-plugin-react-compiler": "catalog:react",
    "citty": "catalog:utils",
    "clsx": "catalog:react",
    "defu": "catalog:utils",
    "fast-equals": "catalog:utils",
    "html-to-image": "1.11.11",
    "json5": "catalog:utils",
    "ky": "^1.14.3",
    "motion": "catalog:react",
    "nanostores": "catalog:react",
    "oxlint": "catalog:",
    "p-limit": "catalog:utils",
    "postcss": "catalog:css",
    "react-error-boundary": "catalog:react",
    "react-resizable-panels": "catalog:react",
    "remeda": "catalog:utils",
    "rolldown": "catalog:tsdown",
    "std-env": "catalog:externals",
    "strip-indent": "catalog:utils",
    "superjson": "catalog:utils",
    "tinyrainbow": "catalog:utils",
    "tsdown": "catalog:tsdown",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "type-fest": "catalog:externals",
    "typescript": "catalog:",
    "ufo": "catalog:utils",
    "vite": "catalog:vite",
    "vite-plugin-dts": "catalog:vite",
    "vitest": "catalog:vitest",
    "xstate": "catalog:xstate",
    "zod": "catalog:externals",
    "zx": "catalog:"
  }
}
