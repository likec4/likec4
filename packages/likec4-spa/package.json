{
  "name": "@likec4/spa",
  "private": true,
  "description": "Single-page application for rendering architecture diagrams",
  "version": "1.55.1",
  "license": "MIT",
  "homepage": "https://likec4.dev",
  "author": "Denis Davydkov <denis@davydkov.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/likec4/likec4.git",
    "directory": "packages/likec4-spa"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --build --verbose",
    "generate": "tsr generate",
    "clean": "likec4ops clean",
    "dev": "tsx watch --conditions=sources --exclude=\"./../../{examples,e2e}/**/*.{js,ts,mjs}\" --exclude=\"./../core/src/styles/**/*.{js,ts,mjs}\" ./start-dev.ts",
    "dev:docs": "pnpm dev ../../apps/docs/src",
    "dev:playground:deployment": "pnpm dev ../../apps/playground/src/examples/deployment",
    "dev:playground:dynamic": "pnpm dev ../../apps/playground/src/examples/dynamic",
    "dev:template": "pnpm dev ../create-likec4/template",
    "dev:e2e": "pnpm dev ../../e2e/src",
    "test": "vitest run --no-isolate",
    "vitest:ui": "vitest --no-isolate --ui"
  },
  "dependencies": {
    "@likec4/core": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "type-fest": "catalog:externals"
  },
