{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@likec4/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "esnext",
    "verbatimModuleSyntax": true,
    "composite": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "allowJs": true,
    "paths": {
      "@likec4/styles/*": [
        "./styled-system/*/index.mjs"
      ]
    }
  },
  "include": [
    "src",
    "styled-system"
  ],
  "references": [
    {
      "path": "../core/"
    },
    {
      "path": "../diagram/tsconfig.src.json"
    }
  ]
}
