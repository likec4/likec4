{
  "name": "@likec4/react",
  "description": "LikeC4 React bundle",
  "private": true,
  "version": "1.58.0",
  "license": "MIT",
  "bugs": "https://github.com/likec4/likec4/issues",
  "homepage": "https://likec4.dev",
  "author": "Denis Davydkov <denis@davydkov.com>",
  "files": [
    "dist",
    "**/package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/likec4/likec4.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "types": "dist/index.d.mts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "sources": "./src/index.ts",
      "default": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "pretypecheck": "pandacss codegen",
    "typecheck": "tsc -b --verbose",
    "build": "vite build",
    "clean": "likec4ops clean"
  },
  "dependencies": {
    "@likec4/core": "workspace:*",
    "immer": "catalog:utils",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "use-sync-external-store": "catalog:react"
  },
  "devDependencies": {
    "type-fest": "catalog:externals",
    "@babel/core": "catalog:react",
    "@likec4/devops": "workspace:*",
    "@likec4/diagram": "workspace:*",
    "@likec4/styles": "workspace:*",
    "@likec4/style-preset": "workspace:*",
    "@likec4/tsconfig": "workspace:*",
    "@microsoft/api-extractor": "^7.58.7",
    "@pandacss/dev": "catalog:css",
    "@react-hookz/web": "catalog:react",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@xyflow/react": "catalog:xyflow",
    "@xyflow/system": "catalog:xyflow",
    "@xstate/react": "catalog:xstate",
    "@xstate/store": "catalog:xstate",
    "@rolldown/plugin-babel": "catalog:vite",
    "@vitejs/plugin-react": "catalog:vite",
    "babel-plugin-react-compiler": "catalog:react",
    "xstate": "catalog:xstate",
    "rolldown": "catalog:tsdown",
    "oxlint": "catalog:",
    "vite-plugin-dts": "catalog:vite",
    "vite": "catalog:vite",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "zx": "catalog:"
  }
}
